---
import '@/styles/global.css';
import LanguageSwitcher from '@/components/LanguageSwitcher.astro';
import { t, url, type Locale } from '@/i18n/ui';

interface Props { locale: Locale; title: string }
const { locale, title } = Astro.props;
---
<!doctype html>
<html lang={locale === 'es' ? 'es-CL' : 'en-US'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {t(locale, 'site.title')}</title>
  </head>
  <body class="min-h-screen bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100">
    <header class="border-b border-zinc-200 dark:border-zinc-800">
      <nav class="mx-auto flex max-w-4xl items-center justify-between gap-4 px-4 py-3">
        <a href={url(locale)} class="font-bold">{t(locale, 'site.title')}</a>
        <div class="flex items-center gap-4">
          <a href={url(locale, 'assessment')} class="text-sm">{t(locale, 'nav.assessment')}</a>
          <LanguageSwitcher locale={locale} />
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-4xl px-4 py-8">
      <slot />
    </main>
  </body>
</html>
